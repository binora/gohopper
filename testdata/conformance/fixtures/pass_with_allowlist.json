{
  "name": "pass_with_allowlist",
  "allowlist": {
    "json_paths": ["info.took"],
    "header_keys": ["x-gh-took"]
  },
  "gh": {
    "status": 200,
    "headers": {
      "content-type": "application/json",
      "x-gh-took": "12"
    },
    "json": {
      "info": {"took": 12, "version": "11.0"},
      "paths": [{"distance": 1000, "time": 60000}]
    }
  },
  "go": {
    "status": 200,
    "headers": {
      "content-type": "application/json",
      "x-gh-took": "9"
    },
    "json": {
      "info": {"took": 9, "version": "11.0"},
      "paths": [{"distance": 1000, "time": 60000}]
    }
  },
  "expect_equal": true
}
